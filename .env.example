# Active profiles (examples: dev, oauth, prod)
SPRING_PROFILES_ACTIVE=dev

# JWT
JWT_SECRET=change-me-with-a-strong-secret
JWT_EXPIRATION_SECONDS=3600

# Frontend redirect after OAuth success
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:4200/auth/login

# CORS allowed origins/patterns, separated by commas.
# Prefer using your exact Vercel project patterns in production, for example:
# http://localhost:4200,https://your-project.vercel.app,https://your-project-*.vercel.app
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:4200,https://*.vercel.app

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Production database
DB_URL=jdbc:postgresql://localhost:5432/freelanceapp
DB_USERNAME=
DB_PASSWORD=
